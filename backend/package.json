{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "LotTrace Express REST API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "knex": "knex --knexfile knexfile.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "migrate:status": "knex migrate:status --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "pg": "^8.11.5",
    "knex": "^3.1.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.0.2",
    "argon2": "^0.31.2",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2"
  },
  "nodemonConfig": {
    "watch": ["src/"],
    "ext": "js,json",
    "ignore": ["src/**/*.test.js"]
  }
}
