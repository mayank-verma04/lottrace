meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@example.com",
    "password": "Password123!",
    "firstName": "Admin",
    "lastName": "User",
    "organizationName": "Test Org"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000/api/v1
}
